{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sparky",
  "version": "0.6.5",
  "identifier": "com.sparky.chat",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd app && pnpm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Sparky",
        "width": 1200,
        "height": 800,
        "minWidth": 950,
        "minHeight": 500,

        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false,
        "backgroundColor": [242, 242, 242, 0]
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' blob: data:; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://unpkg.com",
      "dangerousDisableAssetCspModification": true
    }
  },
  "plugins": {
    "shell": {
      "open": ".*"
    },
    "updater": {
      "endpoints": [
        "https://github.com/lepijohnny/sparky/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCQTQwMDg3QjkwN0FFM0EKUldRNnJnZTVod0NrcS8xVFdOZkY5bFpNYzZzNzFpQzZDckFVYnRhZXVaNmRIMkdLU2xic24vSWUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "copyright": "Copyright © 2026 Nikola Radin.",
    "resources": [
      "../server/dist/**/*",
      "binaries/sparky-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsi"
      }
    }
  }
}
